  { id:"3",  cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 1 AP con 1 PUNTO DE RED",              p12:47000,  p3:53000,  p4:57000  },
  { id:"4",  cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 1 AP con 2 PUNTOS DE RED",             p12:48000,  p3:55000,  p4:60000  },
