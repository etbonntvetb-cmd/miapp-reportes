  { id:"9",  cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 2 PUNTOS DE RED",                      p12:48000,  p3:55000,  p4:60000  },
  { id:"10", cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 3 AP",                                 p12:54000,  p3:60000,  p4:65000  },
  { id:"11", cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 3 AP con 1 PUNTO DE RED",              p12:56000,  p3:62000,  p4:68000  },
  { id:"12", cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 3 AP con 2 PUNTOS DE RED",             p12:64000,  p3:72000,  p4:75000  },
  { id:"13", cat:"single-duo", nombre:"HC SINGLE o DUO con ONT con 4 AP",                                 p12:56000,  p3:64000,  p4:70000  },
  { id:"14", cat:"single-duo", nombre:"HC 